# =========================
# Required
# =========================

# Prisma/Postgres connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/finance_db?schema=public

# JWT secrets (must be long/random in production)
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret

# Frontend URLs used by CORS and auth refresh checks
# Example: https://your-app.pages.dev
FRONTEND_ORIGIN=https://your-frontend-domain.pages.dev
FRONTEND_URL=https://your-frontend-domain.pages.dev


# =========================
# Recommended (production)
# =========================

# Backend public URL
APP_URL=https://your-backend-domain.com

# Cloud platform usually injects PORT automatically
PORT=3000
NODE_ENV=production


# =========================
# Optional (defaults exist)
# =========================

# JWT TTLs
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Email sending (if SMTP_HOST is empty, emails are logged to console)
EMAIL_FROM=no-reply@your-domain.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30


# =========================
# Legacy/unused in current codepath
# =========================
# Kept in config.ts but currently not used by Prisma.
# DB_USER=postgres
# DB_HOST=localhost
# DB_NAME=finance_db
# DB_PASSWORD=
# DB_PORT=5432
